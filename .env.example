# API key de Groq (gratis en https://console.groq.com -> API Keys)
GROQ_API_KEY=gsk_tu_key_aca

# Hash de contraseña (generar con: python3 generar_hash.py)
PASSWORD_HASH=pegar_hash_aca

# Clave secreta para sesiones (generar con: python3 -c "import os; print(os.urandom(32).hex())")
SECRET_KEY=pegar_clave_random_aca
