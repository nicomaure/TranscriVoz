# Copiar a /etc/systemd/system/transcriptor.service
# Editar User, Group y WorkingDirectory segun tu servidor
# Luego: sudo systemctl enable --now transcriptor

[Unit]
Description=TranscriVoz
After=network.target

[Service]
User=tu-usuario
Group=tu-usuario
WorkingDirectory=/ruta/a/transcriptor-groq
Environment="PATH=/ruta/a/transcriptor-groq/venv/bin:/usr/bin:/usr/local/bin"
ExecStart=/ruta/a/transcriptor-groq/venv/bin/gunicorn \
    --worker-class gevent \
    --workers 1 \
    --bind unix:/tmp/transcriptor-groq.sock \
    --timeout 600 \
    wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
